{
  "name": "tribunal-kit",
  "version": "5.8.1",
  "description": "Anti-Hallucination AI Agent Kit for IDEs (Cursor, VSCode, Windsurf) — 43 specialist agents, 34 workflows, 20 parallel Tribunal code reviewers, Model Context Protocol (MCP) server, and long-running autonomous agent harness.",
  "keywords": [
    "ai",
    "ai-agent",
    "long-running-agents",
    "agent",
    "agents",
    "multi-agent",
    "agentic",
    "swarm",
    "orchestration",
    "llm",
    "anti-hallucination",
    "hallucination",
    "code-review",
    "code-quality",
    "cursor",
    "cursor-rules",
    "cursorrules",
    "windsurf",
    "copilot",
    "cline",
    "gemini",
    "antigravity",
    "tribunal",
    "mcp",
    "model-context-protocol",
    "cli",
    "devtools",
    "ai-coding",
    "autonomous-agents",
    "coding-assistant",
    "automation",
    "model-context-protocol-server",
    "mcp-server",
    "claude-code",
    "aider",
    "cursor-rules-generator",
    "agentic-ai",
    "ai-code-reviewer",
    "hallucination-mitigation",
    "autonomous-workflows",
    "code-correctness"
  ],
  "homepage": "https://github.com/Harmitx7/tribunal-kit",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Harmitx7/tribunal-kit.git"
  },
  "license": "MIT",
  "bin": {
    "tribunal-kit": "bin/wrapper.js",
    "tk": "bin/wrapper.js"
  },
  "files": [
    "bin/",
    "dist/",
    "scripts/",
    ".agent/",
    "README.md",
    "LICENSE",
    "mcp_config.json"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "npm run validate-payload && jest --coverage",
    "test:unit": "jest test/unit --coverage",
    "test:integration": "jest test/integration --coverage",
    "preversion": "node scripts/sync-version.js",
    "version": "node scripts/changelog.js && git add CHANGELOG.md",
    "changelog": "node scripts/changelog.js",
    "changelog:preview": "node scripts/changelog.js --preview",
    "sync": "node scripts/sync-version.js",
    "validate-payload": "node scripts/validate-payload.js",
    "benchmark": "node scripts/benchmark.js",
    "benchmark:rust": "cargo build --release && node scripts/benchmark.js",
    "build": "echo 'No build step required for this project'"
  },
  "devDependencies": {
    "eslint": "^9.1.1",
    "jest": "^30.4.2",
    "typescript": "^5.4.5"
  },
  "optionalDependencies": {
    "@tribunal-kit/core-darwin-arm64": "^5.8.1",
    "@tribunal-kit/core-darwin-x64": "^5.8.1",
    "@tribunal-kit/core-linux-arm64": "^5.8.1",
    "@tribunal-kit/core-linux-x64": "^5.8.1",
    "@tribunal-kit/core-win32-arm64": "^5.8.1",
    "@tribunal-kit/core-win32-x64": "^5.8.1"
  },
  "jest": {
    "testMatch": [
      "**/test/**/*.test.js"
    ],
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "bin/**/*.js"
    ]
  }
}
