# Tribunal Kit — npm publish rules
# When .npmignore exists, npm uses THIS file (not .gitignore)
# The "files" field in package.json acts as an allowlist on top of this.

# Exclude dev/test infrastructure
test/
tests/
scratch/
coverage/
.nyc_output/
.pytest_cache/
__pycache__/

# Exclude dev tooling
*.log
.editorconfig
eslint.config.js
tsconfig.json

# Exclude git
.git/
.gitignore

# Exclude OS files
.DS_Store
Thumbs.db
desktop.ini

# Exclude editor configs
.vscode/
.idea/
*.swp
*.swo

# Exclude Python cache
*.pyc
*.pyo

# Exclude build artifacts & dev-only files
node_modules/
target/
crates/
Cargo.toml
Cargo.lock
benchmark-results.json
*.tgz

# Exclude env secrets
.env
.env.local
.env.production
.env.*.local

# Exclude AI IDE Configuration (user-project files, not part of the kit)
.gemini/
.cursorrules
.windsurfrules

# DO NOT exclude these — they are required for tribunal-kit to function:
# .agent/  → intelligence payload
# bin/     → CLI entry points
# dist/    → modular CLI + TypeScript types
# scripts/ → sync/changelog utilities
