# Tribunal Kit — npm publish rules
# When .npmignore exists, npm uses THIS file (not .gitignore)
# The "files" field in package.json acts as an allowlist on top of this.

# Exclude dev/test infrastructure
test/
tests/
scratch/
coverage/
.nyc_output/
.pytest_cache/
__pycache__/

# Exclude dev tooling
*.log
.editorconfig

# Exclude git
.git/
.gitignore

# Exclude OS files
.DS_Store
Thumbs.db
desktop.ini

# Exclude editor configs
.vscode/
.idea/
*.swp
*.swo

# Exclude Python cache
*.pyc
*.pyo

# Exclude build artifacts
dist/
build/
node_modules/

# Exclude env secrets
.env
.env.local
.env.production
.env.*.local

# DO NOT exclude .agent/ — it is required for tribunal-kit to function
# npm's default behavior skips dot-folders, .npmignore overrides that
